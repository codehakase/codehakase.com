{
  "version": 2,
  "buildCommand": "hugo --gc --minify && bash scripts/validate.sh",
  "outputDirectory": "public",
  "build": {
    "env": {
      "HUGO_VERSION": "0.143.1"
    }
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/index.xml",
      "destination": "/blog/index.xml",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
